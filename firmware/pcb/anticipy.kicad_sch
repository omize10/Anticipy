  (wire (pts (xy 100 130) (xy 85 130)) (stroke (width 0) (type default)) (uuid "w-batt-p-to-r1"))
  (wire (pts (xy 100 144) (xy 100 146)) (stroke (width 0) (type default)) (uuid "w-r1-r2-mid"))
  (wire (pts (xy 100 146) (xy 105 146)) (stroke (width 0) (type default)) (uuid "w-batt-adc-to-u1"))
  (wire (pts (xy 100 154) (xy 100 157)) (stroke (width 0) (type default)) (uuid "w-r2-bot"))

  ;; TP4056 power connections
  (wire (pts (xy 107 165) (xy 85 165)) (stroke (width 0) (type default)) (uuid "w-batt-p-tp"))
  (wire (pts (xy 133 165) (xy 140 165)) (stroke (width 0) (type default)) (uuid "w-tp-out-sw"))
  (wire (pts (xy 150 165) (xy 135 108)) (stroke (width 0) (type default)) (uuid "w-sw-5v-u1"))

