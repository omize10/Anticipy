  ;; ─── Wires ────────────────────────────────────────────────────────────────

  ;; I2S connections: U1 GPIO6 → MIC1 SCK
  (wire (pts (xy 105 100) (xy 72 100)) (stroke (width 0) (type default)) (uuid "w-i2s-bclk"))
  ;; U1 GPIO7 → MIC1 WS
  (wire (pts (xy 105 98) (xy 72 102)) (stroke (width 0) (type default)) (uuid "w-i2s-lrck"))
  ;; U1 GPIO8 → MIC1 SD
  (wire (pts (xy 105 96) (xy 72 105)) (stroke (width 0) (type default)) (uuid "w-i2s-data"))

  ;; LED: U1 GPIO4 → R5 → LED1 DIN
  (wire (pts (xy 105 106) (xy 157 106)) (stroke (width 0) (type default)) (uuid "w-led-gpio"))
  (wire (pts (xy 157 106) (xy 157 100)) (stroke (width 0) (type default)) (uuid "w-led-r5-in"))
  (wire (pts (xy 167 100) (xy 164 100)) (stroke (width 0) (type default)) (uuid "w-led-r5-out"))

  ;; BTN_A: SW1 → U1 GPIO1
  (wire (pts (xy 65 70) (xy 105 112)) (stroke (width 0) (type default)) (uuid "w-btna"))
  ;; BTN_B: SW2 → U1 GPIO3
  (wire (pts (xy 95 70) (xy 105 108)) (stroke (width 0) (type default)) (uuid "w-btnb"))

  ;; Pull-ups R3, R4 top → 3V3
